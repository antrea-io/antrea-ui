{
  "name": "@antrea/ui-components",
  "version": "0.1.0",
  "description": "Antrea UI Web Components built with Lit",
  "type": "module",
  "main": "dist/index.js",
  "module": "dist/index.js",
  "types": "dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    },
    "./dist": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    },
    "./src/tokens.css": "./src/tokens.css"
  },
  "scripts": {
    "build": "vite build && tsc --emitDeclarationOnly",
    "dev": "vite demo --open",
    "test": "vitest",
    "lint": "eslint 'src/**/*.ts' --max-warnings=0"
  },
  "dependencies": {
    "@types/d3": "^7.4.3",
    "d3": "^7.9.0",
    "d3-graphviz": "^5.6.0",
    "is-ip": "^5.0.1",
    "lit": "^3.0.0"
  },
  "devDependencies": {
    "@eslint/js": "^9.31.0",
    "@types/d3-graphviz": "^2.6.10",
    "@vitest/eslint-plugin": "^1.0.1",
    "eslint": "^9.31.0",
    "globals": "^17.0.0",
    "jsdom": "^29.0.0",
    "typescript": "^6.0.0",
    "typescript-eslint": "^8.36.0",
    "vite": "^8.0.0",
    "vitest": "^4.0.5"
  }
}
